<!DOCTYPE html>
<html>
  <head>
    <title>Mind Outline</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <header class="fixed top-0 left-0 z-50 w-full border-b border-gray-200 bg-white shadow-sm">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
        <%= link_to "MindOutline", user_signed_in? ? memos_path : root_path,
            class: "text-xl font-bold text-green-700" %>

        <nav class="flex items-center gap-3">
          <% if user_signed_in? %>
            <%= link_to "ログアウト", destroy_user_session_path,
                data: { turbo_method: :delete },
                class: "rounded-lg bg-red-500 px-3 py-2 text-sm font-semibold text-white hover:bg-red-600" %>
          <% else %>
            <%= link_to "ログイン", new_user_session_path,
                class: "text-sm font-medium text-gray-700 hover:text-green-700" %>
            <%= link_to "新規登録", new_user_registration_path,
                class: "rounded-lg bg-green-600 px-3 py-2 text-sm font-semibold text-white hover:bg-green-700" %>
          <% end %>
        </nav>
      </div>
    </header>

    <main class="pt-20">
      <% flash.each do |type, message| %>
        <% css_class =
          case type.to_sym
          when :notice
            "bg-green-100 text-green-800 border border-green-300"
          when :alert
            "bg-red-100 text-red-800 border border-red-300"
          else
            "bg-gray-100 text-gray-800 border border-gray-300"
          end
        %>

        <div class="mx-4 mt-4 rounded px-4 py-3 <%= css_class %>">
          <%= message %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
