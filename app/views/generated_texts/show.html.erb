<div class="mx-auto max-w-3xl px-4 py-8">
  <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <div class="mb-6 border-b border-gray-200 pb-4">
      <h2 class="text-2xl font-bold text-gray-800">生成結果詳細</h2>
    </div>

    <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
      <div class="mb-4">
        <p class="text-sm font-semibold text-blue-600">
          <%= case @generated_text.kind
              when "organize" then "AI整理"
              when "summary" then "AI要約"
              when "writing" then "文章生成"
              else @generated_text.kind
              end %>
        </p>
      </div>

      <div class="mb-6 rounded-lg bg-gray-50 p-4">
        <p class="whitespace-pre-wrap wrap-break-word text-sm leading-relaxed text-gray-800"><%= @generated_text.content %></p>
      </div>

      <div class="space-y-1 text-sm text-gray-500">
        <p>作成日：<%= l @generated_text.created_at, format: :short %></p>
        <p>更新日：<%= l @generated_text.updated_at, format: :short %></p>
      </div>
    </div>

    <div class="mt-6 flex gap-3">
      <%= link_to "一覧へ戻る", memo_generated_texts_path(@generated_text.memo), class: "rounded-lg bg-blue-600 px-4 py-2 font-semibold text-white hover:bg-blue-700" %>
    </div>
  </div>
</div>