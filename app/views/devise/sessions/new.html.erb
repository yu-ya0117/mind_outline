<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4">
  <div class="w-full max-w-md rounded-2xl bg-white p-8 shadow-md">
    <h2 class="mb-6 text-center text-2xl font-bold text-gray-800">ログイン</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-4">
        <p class="mb-2 text-sm font-semibold text-gray-700">
          <%= f.label :email, "メールアドレス" %>
        </p>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full rounded-lg border border-gray-300 px-3 py-2" %>
      </div>

      <div class="mb-4">
        <p class="mb-2 text-sm font-semibold text-gray-700">
          <%= f.label :password, "パスワード" %>
        </p>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full rounded-lg border border-gray-300 px-3 py-2" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <label class="flex items-center gap-3 cursor-pointer">
          <%= f.check_box :remember_me, class: "h-5 w-5" %>
          <span class="text-sm text-gray-700">ログイン状態を保持する</span>
        </label>
      <% end %>

      <div class="mt-6 text-center">
        <%= f.submit "ログイン",
            class: "w-full inline-block rounded-lg bg-blue-600 px-6 py-3 text-white font-semibold hover:bg-blue-700 sm:w-auto" %>
      </div>
    <% end %>

    <div class="mt-6 text-center text-sm text-gray-600">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>