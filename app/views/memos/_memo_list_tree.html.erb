<div class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <p class="text-lg font-semibold text-gray-800"><%= memo.title %></p>
    </div>

    <div class="shrink-0">
      <%= link_to "詳細", memo_path(memo), class: "rounded-lg bg-blue-600 px-3 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
    </div>
  </div>

  <% if memo.children.any? %>
    <div class="mt-4 space-y-3">
      <% memo.children.each do |child| %>
        <%= render "memo_list_node", memo: child %>
      <% end %>
    </div>
  <% end %>
</div>