<div class="mx-auto max-w-3xl px-4 py-8">
  <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="mb-6 text-2xl font-bold text-gray-800">メモ編集</h2>

    <div class="mb-8">
      <%= render "memo_tree", memo: @tree_root, current_memo: @memo %>
    </div>

    <%= render "shared/error_messages", resource: @memo %>

    <%= form_with model: @memo, local: true do |f| %>
      <div class="mb-4">
        <%= f.label :title, "タイトル", class: "mb-2 block text-sm font-semibold text-gray-700" %>
        <%= f.text_field :title, class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-blue-500 focus:outline-none" %>
      </div>

      <div class="mb-4">
        <%= f.label :content, "内容", class: "mb-2 block text-sm font-semibold text-gray-700" %>
        <%= f.text_area :content, rows: 8, class: "w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-blue-500 focus:outline-none" %>
      </div>

      <p class="mb-2 text-sm font-semibold text-gray-700">現在のタグ</p>
      <div class="mb-4 flex flex-wrap gap-2">
        <% if @memo.tags.any? %>
          <% @memo.tags.each do |tag| %>
            <span class="inline-block rounded-full bg-blue-100  px-3 py-1 text-xs text-blue-500">
              <%= tag.name %>
            </span>
          <% end %>
        <% else %>
          <p class="text-sm text-gray-400">タグはまだありません</p>
        <% end %>
      </div>

      <div class="mb-6">
        <p class="mb-2 text-sm font-semibold text-gray-700">
          <%= label_tag :tag_names, "タグ" %>
        </p>
        <%= text_field_tag :tag_names,
            @memo.tags.pluck(:name).join(", "),
            placeholder: "例: Ruby, Rails, Webアプリ",
            class: "w-full rounded-lg border border-gray-300 px-3 py-2" %>
        <p class="mt-1 text-sm text-gray-800">カンマ区切りで入力してください</p>
      </div>

      <div class="grid grid-cols-2 sm:flex gap-3">
        <%= f.submit "更新する", 
            class: "rounded-lg bg-green-600 px-4 py-2 font-semibold text-white hover:bg-green-700" %>
        <%= link_to "メモ詳細へ戻る", memo_path(@memo), 
            class: "rounded-lg bg-gray-200 px-4 py-2 text-gray-800 font-semibold hover:bg-gray-300" %>
      </div>
    <% end %>

    <div class="mt-8 mb-6 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
      <h3 class="mb-4 text-xl font-bold text-gray-800">子メモを追加</h3>
      <%= render "shared/error_messages", resource: @child_memo %>

      <%= form_with model: @child_memo, url: save_child_memo_path(@memo), local: true do |f| %>
        <div class="mb-4">
          <%= f.label :title, "タイトル", class: "mb-2 block text-sm font-semibold text-gray-700" %>
          <%= f.text_field :title, class: "w-full rounded-lg border border-gray-300 px-3 py-2" %>
        </div>

        <div class="mb-4">
          <%= f.label :content, "内容", class: "mb-2 block text-sm font-semibold text-gray-700" %>
          <%= f.text_area :content, rows: 4, class: "w-full rounded-lg border border-gray-300 px-3 py-2" %>
        </div>

        <%= f.submit "子メモを追加", class: "w-full rounded-lg bg-green-600 px-4 py-2 font-semibold text-white hover:bg-green-700 sm:w-auto" %>
      <% end %>
    </div>
    <%= link_to "AI処理", ai_tools_memo_path(@memo), class: "w-full inline-block rounded-lg bg-blue-600 px-4 py-2 font-semibold text-center text-white hover:bg-blue-700 sm:w-auto" %>
  </div>
</div>