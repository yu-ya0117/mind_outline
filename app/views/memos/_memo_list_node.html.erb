<div class="ml-4 border-l-2 border-gray-300 pl-4">
  <p class="font-semibold text-gray-800"><%= memo.title %></p>

  <% if memo.children.any? %>
    <div class="mt-3 space-y-3">
      <% memo.children.each do |child| %>
        <%= render "memo_list_node", memo: child %>
      <% end %>
    </div>
  <% end %>
</div>