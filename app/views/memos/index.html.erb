<div class="mx-auto max-w-4xl px-4 py-8">
  <h2 class="mb-6 text-2xl font-bold text-gray-800">ホーム</h2>

  <% if @memos.any? %>
    <div class="space-y-4">
      <% @memos.each do |memo| %>
        <%= render "memo_list_tree", memo: memo %>
      <% end %>
    </div>
  <% else %>
    <p class="text-gray-500">メモがまだありません。</p>
  <% end %>
</div>