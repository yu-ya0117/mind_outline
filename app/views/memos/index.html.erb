<div class="min-h-screen bg-gray-50 px-4 py-8">
  <div class="mx-auto max-w-3xl">
    <div class="mb-6 rounded-2xl bg-white p-6 shadow-md">
      <h2 class="mb-2 text-2xl font-bold text-gray-800">ホーム</h2>
      <p class="mb-4 text-gray-600"><%= current_user.name %>さん</p>

      <div class="flex gap-3">
        <%= link_to "新規メモ作成", new_memo_path,
            class: "rounded-lg bg-green-600 px-4 py-2 text-white font-semibold hover:bg-green-700" %>

        <%= link_to "ログアウト", destroy_user_session_path,
            data: { turbo_method: :delete },
            class: "rounded-lg bg-gray-200 px-4 py-2 text-gray-800 font-semibold hover:bg-gray-300" %>
      </div>
    </div>

    <div class="rounded-2xl bg-white p-6 shadow-md">
      <h3 class="mb-4 text-xl font-bold text-gray-800">メモ一覧</h3>

      <% if @memos.any? %>
        <div class="space-y-3">
          <% @memos.each do |memo| %>
            <div class="flex justify-between items-center rounded-xl border border-gray-200 p-4">
              <p class="font-semibold text-gray-800"><%= memo.title %></p>
              <%= link_to "詳細", memo_path(memo), class: "ml-2 rounded-lg bg-blue-600 px-4 py-2 font-semibold text-white hover:bg-blue-700" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-500">まだメモがありません。</p>
      <% end %>
    </div>
  </div>
</div>